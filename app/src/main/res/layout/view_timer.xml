<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/timer_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="72sp"
        android:layout_weight="1"
        android:maxLength="8"
        android:background="@color/bg_primary"
        android:gravity="center"
        android:text=""
        android:hint="00:00:00" />

    <LinearLayout
        android:id="@+id/edit_view"
        android:visibility="gone"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <EditText
            android:id="@+id/timer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:inputType="number"
            android:digits="0123456789"
            android:textSize="72sp"
            android:maxLength="6"
            android:background="@color/bg_primary"
            android:gravity="center"
            android:text=""
            android:hint="HHMMSS"
            android:cursorVisible="false"
            android:textIsSelectable="false" />
    </LinearLayout>

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.rama.txori.widgets.WdButton
            android:id="@+id/add_timer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save timer"
            android:visibility="gone"
            android:layout_marginBottom="8sp"
            android:background="@color/button_secondary_color" />

        <com.rama.txori.widgets.WdButton
            android:id="@+id/start_timer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start timer"
            android:layout_marginBottom="8sp"
            android:background="@color/button_secondary_color" />

        <com.rama.txori.widgets.WdButton
            android:id="@+id/reset_timer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reset timer"
            android:layout_marginBottom="8sp"
            android:background="@color/button_secondary_color" />

        <com.rama.txori.widgets.WdButton
            android:id="@+id/edit_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Switch to Edit Mode"
            android:layout_marginBottom="8sp"
            android:background="@color/button_secondary_color" />

        <com.rama.txori.widgets.WdNavbar
            android:id="@+id/navbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
</LinearLayout>