<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_color">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start">

        <com.rama.adiskide.widgets.WdButton
            android:id="@+id/about_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/button_secondary_color"
            android:text="@string/about_main_project_label" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/disabled"
            android:layout_marginVertical="16sp" />

        <com.rama.adiskide.widgets.WdButton
            android:id="@+id/close_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/button_primary_color"
            android:text="@string/go_back_label" />
    </LinearLayout>
</ScrollView>