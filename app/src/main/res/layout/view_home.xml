<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/bgColor"
    android:textColor="?attr/foregroundColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="32sp"
        android:gravity="center"
        android:layout_marginBottom="16sp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:layout_gravity="center"
            android:textColor="@color/foreground_color"
            android:id="@+id/current_task_name"
            android:text="Chest Opener" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="56sp"
            android:layout_marginBottom="8sp"
            android:layout_gravity="center"
            android:textColor="@color/foreground_color"
            android:id="@+id/current_task_timer"
            android:text="02:00" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:showDividers="middle">

            <FrameLayout
                android:id="@+id/repeat_task"
                android:background="@color/bg_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16sp"
                android:padding="12sp">

                <ImageView
                    android:layout_width="24sp"
                    android:layout_height="24sp"
                    android:src="@drawable/icon_refresh"
                    android:textSize="16sp" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/increase_duration"
                android:background="@color/bg_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16sp"
                android:padding="12sp">

                <ImageView
                    android:layout_width="24sp"
                    android:layout_height="24sp"
                    android:src="@drawable/icon_arrow_up"
                    android:textSize="16sp" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/complete_task"
                android:background="@color/bg_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16sp"
                android:padding="12sp">

                <ImageView
                    android:layout_width="24sp"
                    android:layout_height="24sp"
                    android:src="@drawable/icon_octagon_check_solid"
                    android:textSize="16sp" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/skip_task"
                android:background="@color/bg_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="12sp">

                <ImageView
                    android:layout_width="24sp"
                    android:layout_height="24sp"
                    android:src="@drawable/icon_next"
                    android:textSize="16sp" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/group_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="[-] Workout :: 40 Tasks :: 44m"
            android:textSize="18sp"
            android:paddingTop="12sp"
            android:paddingBottom="12sp"
            android:textColor="@color/foreground_color" />

        <FrameLayout
            android:id="@+id/start_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="12sp">

            <ImageView
                android:id="@+id/start_group_icon"
                android:layout_width="18sp"
                android:layout_height="18sp"
                android:src="@drawable/icon_play"
                android:textSize="16sp" />
        </FrameLayout>

    </LinearLayout>

    <ListView
        android:id="@+id/task_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:divider="@android:color/transparent"
        android:dividerHeight="8sp"
        android:layout_marginBottom="8sp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/home_nav"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/button_primary_color"
            android:layout_marginEnd="2dp"
            android:layout_weight="1"
            android:padding="12sp">

            <ImageView
                android:layout_width="24sp"
                android:layout_height="24sp"
                android:layout_gravity="center"
                android:src="@drawable/icon_home"
                android:textSize="16sp" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/stopwatch_nav"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/button_primary_color"
            android:layout_marginEnd="2dp"
            android:layout_weight="1"
            android:padding="12sp">

            <ImageView
                android:layout_width="24sp"
                android:layout_height="24sp"
                android:layout_gravity="center"
                android:src="@drawable/icon_clock"
                android:textSize="16sp" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/timer_nav"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/button_primary_color"
            android:layout_marginEnd="2dp"
            android:layout_weight="1"
            android:padding="12sp">

            <ImageView
                android:layout_width="24sp"
                android:layout_height="24sp"
                android:layout_gravity="center"
                android:src="@drawable/icon_clock"
                android:textSize="16sp" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/settings_nav"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/button_primary_color"
            android:layout_marginEnd="2dp"
            android:layout_weight="1"
            android:padding="12sp">

            <ImageView
                android:layout_width="24sp"
                android:layout_height="24sp"
                android:layout_gravity="center"
                android:src="@drawable/icon_cog"
                android:textSize="16sp" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/about_nav"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/button_primary_color"
            android:layout_weight="1"
            android:padding="12sp">

            <ImageView
                android:layout_width="24sp"
                android:layout_height="24sp"
                android:layout_gravity="center"
                android:src="@drawable/icon_user"
                android:textSize="16sp" />
        </FrameLayout>
    </LinearLayout>


</LinearLayout>
