<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/bgColor"
    android:textColor="?attr/foregroundColor">

    <LinearLayout
        android:id="@+id/top_bar"
        android:orientation="horizontal"
        android:gravity="end|center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <FrameLayout
            android:id="@+id/toggle_visibility"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="12sp">

            <ImageView
                android:id="@+id/toggle_visibility_img"
                android:layout_width="24sp"
                android:layout_height="24sp"
                android:src="@drawable/icon_cog"
                android:textSize="16sp"
                android:contentDescription="Toggle Visibility" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="32sp"
        android:gravity="center"
        android:layout_marginBottom="16sp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:layout_gravity="center"
            android:textColor="@color/foreground_color"
            android:text="Chest Opener" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="56sp"
            android:layout_gravity="center"
            android:textColor="@color/foreground_color"
            android:text="02:00" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:showDividers="middle">

            <FrameLayout
                android:id="@+id/repeat_task"
                android:background="@color/bg_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16sp"
                android:padding="12sp">

                <ImageView
                    android:layout_width="24sp"
                    android:layout_height="24sp"
                    android:src="@drawable/icon_octagon_check_solid"
                    android:textSize="16sp" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/start_task"
                android:background="@color/bg_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16sp"
                android:padding="12sp">

                <ImageView
                    android:layout_width="24sp"
                    android:layout_height="24sp"
                    android:src="@drawable/icon_octagon_check_solid"
                    android:textSize="16sp" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/complete_task"
                android:background="@color/bg_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16sp"
                android:padding="12sp">

                <ImageView
                    android:layout_width="24sp"
                    android:layout_height="24sp"
                    android:src="@drawable/icon_octagon_check_solid"
                    android:textSize="16sp" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/skip_task"
                android:background="@color/bg_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16sp"
                android:padding="12sp">

                <ImageView
                    android:layout_width="24sp"
                    android:layout_height="24sp"
                    android:src="@drawable/icon_octagon_check_solid"
                    android:textSize="16sp" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/increase_duration"
                android:background="@color/bg_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="12sp">

                <ImageView
                    android:layout_width="24sp"
                    android:layout_height="24sp"
                    android:src="@drawable/icon_octagon_check_solid"
                    android:textSize="16sp" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="[-] Workout :: 40 Tasks :: 44m"
            android:textSize="24sp"
            android:paddingTop="12sp"
            android:paddingBottom="12sp"
            android:textColor="@color/foreground_color" />

        <FrameLayout
            android:id="@+id/start_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="12sp">

            <ImageView
                android:layout_width="24sp"
                android:layout_height="24sp"
                android:src="@drawable/icon_octagon_check_solid"
                android:textSize="16sp" />
        </FrameLayout>

    </LinearLayout>

    <ListView
        android:id="@+id/task_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:divider="@android:color/transparent"
        android:dividerHeight="8sp"
        android:layout_marginBottom="8sp"
        android:layout_weight="1" />

    <com.rama.adiskide.widgets.WdButton
        android:id="@+id/add_task_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/button_secondary_color"
        android:text="@string/add_task" />

</LinearLayout>
